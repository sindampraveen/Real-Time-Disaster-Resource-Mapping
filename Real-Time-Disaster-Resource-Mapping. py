@api_view(["POST"])
def add_safe_place_api(request):
    name = request.data.get("name")
    address = request.data.get("address")
    contact = request.data.get("contact")
    if not all([name, address, contact]):
        return Response({"error": "All fields required"})
    con = get_db_connection()
    with con:
        cur = con.cursor()
        cur.execute("""
            INSERT INTO safe_places (name, address, contact)
            VALUES (%s,%s,%s)
        """, (name, address, contact))
        con.commit()
    return Response({"success": "Safe place added"})
@api_view(["POST"])
def update_safe_place_api(request):
    place_id = request.data.get("id")
    name = request.data.get("name")
    address = request.data.get("address")
    contact = request.data.get("contact")
    con = get_db_connection()
    with con:
        cur = con.cursor()
        cur.execute("""
            UPDATE safe_places
            SET name=%s, address=%s, contact=%s
            WHERE id=%s
        """, (name, address, contact, place_id))
        con.commit()
    return Response({"success": "Safe place updated"})
@api_view(["GET"])
def view_safe_places_api(request):
    con = get_db_connection()
    with con:
        cur = con.cursor(pymysql.cursors.DictCursor)
        cur.execute("SELECT * FROM safe_places")
        places = cur.fetchall()
    return Response({"places": places})
