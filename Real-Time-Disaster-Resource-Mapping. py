import "./Admin.css";
import axios from "axios";
import { useEffect, useState } from "react";
import { NavLink } from "react-router-dom";
const Admin = () => {
  const [users, setUsers] = useState([]);
  const [safePlaces, setSafePlaces] = useState([]);

  // section toggle: "", "users", "addSafe", "manageSafe"
  const [section, setSection] = useState("");
  const [place, setPlace] = useState({
    name: "",
    address: "",
    contact: "",
  });
  const [isEdit, setIsEdit] = useState(false);
  const [editId, setEditId] = useState(null);
  const loadUsers = async () => {
    const res = await axios.get("http://127.0.0.1:8000/api/admin/user/");
    setUsers(res.data.users || []);
  };
  const loadSafePlaces = async () => {
    const res = await axios.get(
      "http://127.0.0.1:8000/api/admin/safe-places/"
    );
    setSafePlaces(res.data.places || []);
  };
  useEffect(() => {
    loadUsers();
  }, []);
  const approveUser = async (username) => {
    const res = await axios.post(
      "http://127.0.0.1:8000/api/approve/",
      { username }
    );
    alert(res.data.success);
    loadUsers();
  };
  const addSafePlace = async () => {
    if (!place.name || !place.address || !place.contact) {
      alert("All fields required");
      return;
    }

    if (isEdit) {
      // UPDATE
      await axios.post(
        "http://127.0.0.1:8000/api/admin/update-safe-place/",
        {
          id: editId,
          name: place.name,
          address: place.address,
          contact: place.contact,
        }
      );
      alert("Safe place updated");
    } else {
      // ADD
      await axios.post(
        "http://127.0.0.1:8000/api/admin/add-safe-place/",
        place
      );
      alert("Safe place added");
    }

    // reset
    setPlace({ name: "", address: "", contact: "" });
    setIsEdit(false);
    setEditId(null);
    loadSafePlaces();
    setSection("manageSafe");
  };

  return (
    <>
      <header>
        <div id="brand-name">
          <h1>Disaster Resource Mapping</h1>
        </div>

        <div className="components">
          <NavLink to="/">Home</NavLink>
          <button
            id="details-btn"
            onClick={() => setSection(section === "users" ? "" : "users")}
          >
            User Details
          </button>
          <button
            id="details-btn"
            onClick={() => {
              setIsEdit(false);
              setPlace({ name: "", address: "", contact: "" });
              setSection(section === "addSafe" ? "" : "addSafe");
            }}
          >
            Add Safe Place
          </button>
          <button
            id="details-btn"
            onClick={() => {
              if (section === "manageSafe") {
                setSection("");
              } else {
                setSection("manageSafe");
                loadSafePlaces();
              }
            }}
          >
            Manage Safe Places
          </button>

          <NavLink to="/login">Logout</NavLink>
        </div>
      </header>

      <main>
        <h2>Admin Dashboard</h2>
        {section === "users" && (
          <table id="admin-table" border="1">
            <thead>
              <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Approved</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              {users.map((u, i) => (
                <tr key={i}>
                  <td>{u.username}</td>
                  <td>{u.email}</td>
                  <td>{u.mobile}</td>
                  <td>{u.approved === 1 ? "Yes" : "No"}</td>
                  <td>
                    {u.approved === 0 ? (
                      <button
                        id="approve-btn"
                        onClick={() => approveUser(u.username)}
                      >
                        Approve
                      </button>
                    ) : (
                      "Approved"
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
        {section === "addSafe" && (
          <div id="admin-form">
            <h3 style={{ textAlign: "center", paddingTop: "1.5rem" }}>
              {isEdit ? "Edit Safe Place" : "Add Safe Place"}
            </h3>

            <input
              type="text"
              placeholder="Safe Place Name"
              value={place.name}
              onChange={(e) =>
                setPlace({ ...place, name: e.target.value })
              }
            />
            <textarea
              placeholder="Complete Address"
              value={place.address}
              onChange={(e) =>
                setPlace({ ...place, address: e.target.value })
              }
            />
            <input
              type="text"
              placeholder="Contact Number"
              value={place.contact}
              onChange={(e) =>
                setPlace({ ...place, contact: e.target.value })
              }
            />
            <button id="approve-btn5" onClick={addSafePlace}>
              {isEdit ? "Update" : "Save"}
            </button>
          </div>
        )}
        {section === "manageSafe" && (
          <table id="admin-table" border="1">
            <thead>
              <tr>
                <th>Safe Place</th>
                <th>Addres</th>
                <th>Contact</th>
                <th>Action</th>
              </tr>
            </thead>

            <tbody>
              {safePlaces.map((s, i) => (
                <tr key={i}>
                  <td>{s.name}</td>
                  <td>{s.address}</td>
                  <td>{s.contact}</td>
                  <td>
                    <button
                      id="approve-btn5"
                      onClick={() => {
                        setPlace({
                          name: s.name,
                          address: s.address,
                          contact: s.contact,
                        });
                        setEditId(s.id);
                        setIsEdit(true);
                        setSection("addSafe");
                      }}
                    >
                      Edit
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </main>
      <footer>
        <h4>© 2025 All Rights Reserved SAK Informatics</h4>
      </footer>
    </>
  );
};

