def admin_user_api(request):
    con = get_db_connection()
    with con:
        cur = con.cursor()
        cur.execute("SELECT * FROM users1 WHERE role='user'")
        users = cur.fetchall()
    return Response({"users": users})  
# Admin: Approve any user (user or client)
